# 服务端监听地址和端口。
BIRD_SERVER_HOST=0.0.0.0
BIRD_SERVER_PORT=8010

# 项目路径配置：下面的相对路径都以 BIRD_PROJECT_ROOT 为基准。
BIRD_PROJECT_ROOT=../..
BIRD_MOBILE_APP_DIR=smart-bird-server/App
BIRD_SERVER_WORK_DIR=smart-bird-server/server/work
BIRD_SERVER_CACHE_DIR=smart-bird-server/server/work/cache
BIRD_HISTORY_PATH=smart-bird-server/server/work/sensor_history.json
BIRD_DB_PATH=smart-bird-server/server/work/bird_history.db

# 依赖安装和模型缓存目录：默认都放到 smart-bird-server\.deps 下，便于单独迁移服务端。
BIRD_DEPS_DIR=smart-bird-server/.deps
BIRD_SERVER_VENV_DIR=smart-bird-server/.deps/python/server
PIP_CACHE_DIR=smart-bird-server/.deps/pip-cache
HF_HOME=smart-bird-server/.deps/huggingface
HF_HUB_CACHE=smart-bird-server/.deps/huggingface/hub
TRANSFORMERS_CACHE=smart-bird-server/.deps/huggingface/transformers
MODELSCOPE_CACHE=smart-bird-server/.deps/modelscope
TORCH_HOME=smart-bird-server/.deps/torch
XDG_CACHE_HOME=smart-bird-server/.deps/cache

# 语音识别配置：优先使用 FunASR；fallback 只用于测试整条音频链路。
ASR_PROVIDER=funasr
ASR_FALLBACK_TEXT=

# 大模型配置：qwen_local 使用本机模型；DeepSeek 是可选云端方案。
LLM_PROVIDER=qwen_local
LOCAL_QWEN_MODEL=
LOCAL_LLM_MAX_NEW_TOKENS=48
PRELOAD_MODELS=true

# DeepSeek 配置：使用兼容 OpenAI 接口的云端大模型。
DEEPSEEK_API_KEY=replace_with_your_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=100

# 语音合成配置：sapi 使用 Windows 本机语音；填写百度 Key 后可切换 baidu。
TTS_PROVIDER=sapi
FFMPEG_PATH=FormatFactory/ffmpeg.exe
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
BAIDU_CUID=bird_test
